OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
ADMIN_PANEL_KEY=replace_with_a_long_random_secret
LEAD_WEBHOOK_URL=https://example.invalid/webhooks/geogas-leads
CONTACT_WEBHOOK_URL=
NEWSLETTER_WEBHOOK_URL=
# Gmail SMTP is used for contact/quote and chatbot booking notifications when
# all three values are set. Create an App Password (not your normal password)
# in the Google account that will send the notifications.
GMAIL_SMTP_USER=
GMAIL_SMTP_APP_PASSWORD=
BOOKING_NOTIFICATION_TO=
# Comma-separated public origins permitted to submit chatbot booking requests.
# This is useful when the app runs behind a reverse proxy.
FORM_ALLOWED_ORIGINS=https://www.geogasservices.uk,https://geogasservices.uk
# Competition entries are stored in content/geogas-content.sqlite and can be
# retrieved with an ADMIN_PANEL_KEY via /api/competition/entries.
